{
  "name": "memory-engine",
  "version": "0.0.0",
  "description": "Shared learning engine kernel: canonical types, FSRS reference scheduler, deterministic grading.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testkit": "./testkit/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "coverage": "bun run scripts/check-coverage.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci:local": "bun run typecheck && bun run check && bun run coverage",
    "ci": "dagger call check --source=."
  },
  "dependencies": {
    "ts-fsrs": "^5.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
